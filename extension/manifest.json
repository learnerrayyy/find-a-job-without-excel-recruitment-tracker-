{
  "manifest_version": 3,
  "name": "Job Tracker Capture",
  "version": "0.1.2",
  "description": "Save the current job page into the local Job Application Tracker.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save job"
  },
  "permissions": ["activeTab", "scripting", "nativeMessaging"],
  "host_permissions": ["http://127.0.0.1:8765/*"]
}
